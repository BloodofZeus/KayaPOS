# Required: PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/kaya_pos

# Required in production: Strong random secret for signing session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-this-to-a-strong-random-secret-in-production

# Optional: Port the server listens on (defaults to 5000)
PORT=5000

# Set to "production" for production deployments
NODE_ENV=development
